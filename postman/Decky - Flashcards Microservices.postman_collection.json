    {
      "name": "Daily Session Service",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flashcardsToReview\": [\n    {\n      \"id\": \"{{flashcardId}}\",\n      \"deckId\": \"{{deckId}}\",\n      \"frontText\": \"Bonjour\",\n      \"backText\": \"Hello\",\n      \"tags\": [\"greetings\"],\n      \"extraInfo\": { \"example\": \"Bonjour, comment ça va?\" }\n    }\n  ],\n  \"cardsReviewedToday\": 0\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/api/sessions",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "sessions"]
            }
          },
          "response": []
        },
        {
          "name": "Get Active Session",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/api/sessions?deckId={{deckId}}&batchSize=10",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "sessions"],
              "query": [
                {
                  "key": "deckId",
                  "value": "{{deckId}}"
                },
                {
                  "key": "batchSize",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Submit Session Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/api/sessions/{{flashcardId}}/review?quality=4&deckId={{deckId}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "sessions", "{{flashcardId}}", "review"],
              "query": [
                {
                  "key": "quality",
                  "value": "4"
                },
                {
                  "key": "deckId",
                  "value": "{{deckId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Flush Session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
